# Keep the build context small and never ship secrets or local data.
.git/
.gitignore

# Python
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Secrets and local data (mounted / provided via env at runtime instead)
.env
.env.*
!.env.example
data/

# Dev-only artifacts
tests/
docs/
*.md
